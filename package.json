{
  "name": "slo-watch",
  "version": "0.1.0",
  "private": true,
  "description": "In-memory SLO monitor for configured web targets.",
  "type": "module",
  "scripts": {
    "build": "npm run build:api && npm run build:web",
    "build:api": "tsc -p tsconfig.json",
    "build:web": "vite build --config web/vite.config.ts",
    "dev": "npm run dev:api",
    "dev:api": "node --env-file-if-exists=.env --import tsx --watch src/server.ts",
    "dev:web": "vite --config web/vite.config.ts",
    "lint": "eslint .",
    "start": "node dist/server.js",
    "test": "vitest run",
    "test:container": "bash scripts/verify-container.sh",
    "test:compose": "bash scripts/verify-compose.sh",
    "test:coverage": "vitest run --coverage --coverage.reporter=text --coverage.reporter=html --coverage.reporter=json-summary"
  },
  "engines": {
    "node": ">=24"
  },
  "dependencies": {
    "fastify": "^5.6.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.0",
    "@tailwindcss/vite": "^4.3.3",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^24.0.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^4.0.0",
    "eslint": "^9.39.0",
    "jsdom": "^29.1.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwindcss": "^4.3.3",
    "tsx": "^4.20.0",
    "typescript": "^5.9.0",
    "typescript-eslint": "^8.46.0",
    "vitest": "^4.0.0"
  }
}
